# ============================================================
# gyAI (ADIS) — .gitignore
# Keeps SOURCE in version control; excludes secrets, envs,
# caches, data, and build output.
#
# NOTE: unlike .dockerignore (which trims the runtime image),
# this KEEPS tests/ and scripts/ — they belong in the repo.
# ============================================================

# ---- Secrets & local environment (NEVER commit) ----
.env
.env.*
!.env.example
*.pem
*.key

# ---- Python virtual environments ----
venv/
.venv/
env/
ENV/

# ---- Python caches & build artifacts ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# ---- Node / browser extension ----
node_modules/
scripts/
extension/dist/
extension/node_modules/
# webpack build output (regenerated by `npm run build`)
extension/dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- ML: ignore datasets & intermediate data ----
ml_data/
ml/data/
data/
*.csv
*.tsv
*.parquet
*.feather

# ---- ML pickles: ignore everywhere, then re-include ONLY the
#      production model + encoder the API loads at runtime.
#      (Small ~11MB; REQUIRE_MODEL=true needs them shipped.)
#      The phase1 backup pkl is intentionally left ignored. ----
*.pkl
*.joblib
!ml/models/lgbm_model_v1.1.0.pkl
!ml/models/label_encoder.pkl
# Uncomment the next line if you also want the older model in git:
# !ml/models/lgbm_model_v1.0.0.pkl

# ---- Logs & temp ----
*.log
install_log.txt
*.tmp
*.bak
*.swp

# ---- OS / editor cruft ----
.DS_Store
Thumbs.db
.idea/
.vscode/
*.sublime-*

# ---- Optional: internal design doc (uncomment to keep it private) ----
project_blueprint.md

