{
  "manifest_version": 3,
  "name": "gyAI",
  "version": "1.0.0",
  "description": "Warns you about suspicious or malicious domains as you browse — notification only, never blocks your browsing.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "gyAI",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service_worker.js"
  },
  "permissions": [
    "webNavigation",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://gyai-api.fly.dev/*",
    "https://*/*",
    "http://*/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/content_script.css"],
      "matches": ["https://*/*", "http://*/*"]
    }
  ]
}
